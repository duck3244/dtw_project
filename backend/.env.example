# Copy to backend/.env and edit. Values shown are defaults.

# Recognizer
SAMPLE_RATE=16000
N_MFCC=13
DTW_BACKEND=auto         # auto | core | accel
# DTW_BAND=15            # Sakoe-Chiba band, ~10-20% of sequence length. Empty = no constraint.
SCORE_AGGREGATION=min    # min | mean | knn
KNN_K=3
NORMALIZE=true

# Upload limits
MAX_AUDIO_BYTES=10485760
# Note: tuple type must be set in code; .env can override individual scalars only.

# CORS — comma separated list of dev/prod frontends
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
